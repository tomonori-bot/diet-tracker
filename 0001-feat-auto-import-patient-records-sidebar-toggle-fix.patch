+// 自動インポートバナー（新着通知）を表示
+function showAutoImportBanner(data) {
+  const rec = data.record || {};
+  const chips = [
+    `<span class="new-chip">📅 ${rec.date || ''}</span>`,
+    rec.weight != null ? `<span class="new-chip">⚖️ ${rec.weight}kg</span>` : '',
+    rec.moti    ? `<span class="new-chip">💪 モチベ${rec.moti}/5</span>` : '',
+    rec.exercise != null ? `<span class="new-chip">🏃 運動${rec.exercise}%</span>` : '',
+    rec.memo    ? `<span class="new-chip">💬 ${rec.memo.slice(0,24)}${rec.memo.length>24?'...':''}</span>` : '',
+  ].filter(Boolean).join('');
+  document.getElementById('newChips').innerHTML = chips;
+  document.getElementById('newBanner').style.display = '';
+}
+
 // ブラウザ通知許可を要求
 function requestNotificationPermission() {
